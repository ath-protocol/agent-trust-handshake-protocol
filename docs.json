{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Agent Trust Handshake Protocol",
  "description": "ATH is an open protocol for establishing trusted connections between AI agents and external services, building on OAuth 2.0 with a trusted handshake.",
  "colors": {
    "primary": "#2563EB",
    "light": "#60A5FA",
    "dark": "#1E40AF"
  },
  "background": {
    "color": {
      "light": "#f8f9fc",
      "dark": "#0f172a"
    }
  },
  "favicon": "/favicon.svg",
  "navbar": {
    "primary": {
      "type": "button",
      "label": "GitHub",
      "href": "https://github.com/ath-protocol"
    },
    "links": [
      {
        "label": "Specification",
        "href": "/specification/0.1"
      }
    ]
  },
